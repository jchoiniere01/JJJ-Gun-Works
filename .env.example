# =============================================================================
# JJJ Gun Works LLC — FastAPI backend .env template (Render PostgreSQL).
#
# Copy to `.env` and replace <placeholder> values. Do NOT commit the real .env.
# The legacy SQL Server template lives in archive/sqlserver/.env.sqlserver.example.
# =============================================================================

# ---- PostgreSQL connection --------------------------------------------------
# DATABASE_URL wins over PG_* if both are set. Render provides this value
# automatically via the `fromDatabase` binding in render.yaml.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require

# ---- Optional explicit fallbacks (only used if DATABASE_URL is empty) ------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=firearms_inventory
PG_USER=firearms_app
PG_PASSWORD=
PG_SSLMODE=prefer
PG_TIMEOUT_SECONDS=30

# ---- API settings -----------------------------------------------------------
APP_NAME=Firearms Inventory API
APP_ENV=production
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
