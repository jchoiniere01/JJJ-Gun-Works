# =============================================================================
# JJJ Gun Works LLC — FastAPI backend .env template for Render PostgreSQL.
#
# Copy this file to `.env` in the project root (next to pyproject.toml) and
# replace every <placeholder> with the real value from the Render dashboard.
#
# IMPORTANT: Do NOT commit the real .env. `.gitignore` already excludes
#            `.env`. Also remove the legacy `app/JJJGW.env` before deploy.
# =============================================================================

# ---- PostgreSQL connection ---------------------------------------------------
# Render's managed Postgres exposes both an Internal Database URL (use this
# from any Render service in the same region) and an External Database URL
# (use this from your laptop / CI). Both URLs already include ?sslmode=require.
#
# DATABASE_URL takes precedence over the individual PG_* variables if both
# are set.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require

# ---- Optional explicit fallbacks --------------------------------------------
# Only used if DATABASE_URL is empty. Leave PG_PASSWORD blank in the
# committed template; populate in the local `.env`.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=firearms_inventory
PG_USER=firearms_app
PG_PASSWORD=
PG_SSLMODE=prefer

# ---- API / app settings (unchanged from original .env.example) --------------
APP_NAME=Firearms Inventory API
APP_ENV=production
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Notes ------------------------------------------------------------------
# * When deploying to Render, create the managed Postgres first, then link
#   DATABASE_URL into the web service via Render's "Environment" tab using
#   the "fromDatabase" binding (see render.yaml examples in the guide).
# * Run migrations once (see scripts/run_migrations.ps1 or the guide) with
#   the EXTERNAL database URL before the web service makes its first query.
