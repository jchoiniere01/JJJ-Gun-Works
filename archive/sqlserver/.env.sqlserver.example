# Local SQL Server connection.
# For SQL Server Express, SERVER is often .\\SQLEXPRESS or localhost\\SQLEXPRESS.
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_SERVER=localhost
SQLSERVER_DATABASE=FirearmsInventory
SQLSERVER_TRUSTED_CONNECTION=true
SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=no
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes
SQLSERVER_TIMEOUT_SECONDS=30

# API settings.
APP_NAME=Firearms Inventory API
APP_ENV=local
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: point to your converted schema names if they differ.
# See app/table_config.py for default mappings.
